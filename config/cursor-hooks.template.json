{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "hooks/update-user-rules-on-session-start.js",
        "timeout": 60
      }
    ],
    "postToolUse": [
      {
        "command": "hooks/capture-post-tool-use.js",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "hooks/send-stop-transcript.js",
        "timeout": 20
      }
    ]
  }
}
